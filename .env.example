DB_HOST=localhost
DB_PORT=5432
DB_NAME=job_searcher
DB_USER=user_job_searcher
DB_PASSWORD=
HTTP_ADDR=:7770

# Per-user profile isolation on the public site. Maps the auth proxy's
# Remote-User (Authelia via Caddy) to the one profile that account may see.
# Comma-separated user:profile pairs; the user is matched case-insensitively.
# Leave unset for local dev — with no proxy and no Remote-User header, every
# profile stays accessible. A request from a Remote-User not listed here is
# rejected with 403.
PROFILE_ACCESS=slava:Slava,kezia:Kezia

# DeepSeek (resume tailoring) — see https://api-docs.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# Path to the resume_data.json owned by the resume_htmx project. Now only the
# one-time import source for cmd/seed-resume — the canonical resume lives in the DB.
RESUME_JSON_PATH=/path/to/resume_htmx/resume_data.json

# resume_htmx (Flask) base URL — it renders the tailored resume to PDF via
# WeasyPrint. job_searcher_web POSTs the tailored document to /render-pdf there.
RESUME_HTMX_URL=http://localhost:5050

# --- Hetzner box (deploy target) WireGuard VPN ---
# The Hetzner host hoodatlas.thegoreliks.ca, reachable over a gluetun
# custom-WireGuard tunnel. Fill these (incl. the private key) in your local,
# gitignored .env only — never here. See deploy/hetzner-vpn.md for context.
HETZNER_HOST=hoodatlas.thegoreliks.ca
WIREGUARD_ENDPOINT_IP=62.238.11.206
WIREGUARD_ENDPOINT_PORT=51820
WIREGUARD_ADDRESSES=10.10.0.20/32
WIREGUARD_PUBLIC_KEY=
WIREGUARD_PRIVATE_KEY=
FIREWALL_VPN_INPUT_PORTS=1234,3334
FIREWALL_OUTBOUND_SUBNETS=192.168.1.0/24,172.16.0.0/12

# --- Docker (docker compose up -d) ---
# When running in the container, docker-compose.yml overrides DB_HOST=hub_db
# (the shared Postgres container on project-hub-network), HTTP_ADDR=:7770, and
# RESUME_HTMX_URL=http://host.docker.internal:5050. For a host `go run`, the
# localhost defaults above apply. Only DB_NAME/DB_USER/DB_PASSWORD and the
# DEEPSEEK_* values need to be filled in here for either path.

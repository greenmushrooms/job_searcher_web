DB_HOST=localhost
DB_PORT=5432
DB_NAME=job_searcher
DB_USER=user_job_searcher
DB_PASSWORD=
HTTP_ADDR=:8090

# DeepSeek (resume tailoring) — see https://api-docs.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# Path to the resume_data.json owned by the resume_htmx project.
# Absolute path recommended since the server is usually run from the repo root.
RESUME_JSON_PATH=/path/to/resume_htmx/resume_data.json
